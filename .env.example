# =========================================================
# ZimFire Monitor — environment template
# Copy to ".env" and fill in real values:  cp .env.example .env
# Do NOT commit .env to git. (.dockerignore + .gitignore exclude it.)
# =========================================================

# ---- EUMETSAT / Meteosat (REQUIRED) ----
EUMETSAT_CONSUMER_KEY=your_eumetsat_consumer_key
EUMETSAT_CONSUMER_SECRET=your_eumetsat_consumer_secret
# MTG Active Fire Monitoring collection (default is correct for most cases)
EUM_COLLECTION=EO:EUM:DAT:0682

# ---- NASA FIRMS / VIIRS (REQUIRED) ----
FIRMS_MAP_KEY=your_firms_map_key

# ---- Paths (leave as-is for Docker; these match the image layout) ----
# Defaults inside the container resolve to /app/src/aoi.geojson,
# /app/src/db/alerts.db and /app/output. Only override if you know why.
# AOI_FILE=/app/src/aoi.geojson
# DB_FILE=/app/src/db/alerts.db
# OUTPUT_DIR=/app/output

# ---- Fire detection tuning ----
MIN_CONFIDENCE=0.5
LOOKBACK_HOURS=2
# 900 = 15 minutes between cycles
POLL_INTERVAL_SECONDS=900

# Set to true to run exactly one cycle and exit (useful for testing).
RUN_ONCE=false

# ---- Telerivet SMS (OPTIONAL) ----
# NOTE: this build (main.py) does NOT send SMS — these are read by
# config.py but never used in the monitoring loop. Safe to leave blank
# unless/until SMS dispatch is wired in.
TELERIVET_API_KEY=
TELERIVET_PROJECT_ID=
TELERIVET_GROUP_ID=
ALERT_TO=
